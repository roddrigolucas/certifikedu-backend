model ApiKeys {
  apiKeyId  String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKey    String  @unique
  isDeleted Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AcademicCredentials {
  credentialId String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  emecCode          String
  type              AcademicTypeEnum
  number            Int
  description       String
  issuedAt          DateTime
  publishedDate     DateTime
  publishingVehicle String
  publishingSection String
  publishingPage    String
  numberDOU         Int

  credentialType CredentialTypeEnum

  courseId String?
  course   Course? @relation(fields: [courseId], references: [courseId], onDelete: Cascade)

  schoolId String?
  school   Schools? @relation(fields: [schoolId], references: [schoolId], onDelete: Cascade)

  userId String
  user   PessoaJuridica @relation(fields: [userId], references: [idPJ], onDelete: Cascade)

  @@unique([schoolId])
  @@unique([courseId])
}
