content-type: application/json
ce-api-key: ce_tests_73c65f2a6e21ba97

{
    "receptorDoc": "07455823037",
    "name": "Certificado Teste",
    "description": "Certificado Teste e2e",
    "hoursWorkload": "10",
    "abilities": [
      {
        "ability": "Abilidade Criada via certificado",
        "category": "API"
      }
    ],
