# ============================================================
# CertifikEDU - Variáveis de ambiente para VPS Hostinger
# IP da VPS: 31.97.91.29
#
# Copie este arquivo para .env e preencha com os valores reais:
#   cp .env.vps.example .env
# ============================================================

# -------------------------------------------------------
# BANCO DE DADOS
# -------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SuaSenhaForteAqui123!
POSTGRES_DB=certifikedu

# Gerado automaticamente pelo docker-compose a partir das vars acima.
# Para rodar fora do Docker (ex: prisma studio), use o IP da VPS:
DATABASE_URL=postgresql://postgres:SuaSenhaForteAqui123!@database:5432/certifikedu

# -------------------------------------------------------
# AUTENTICAÇÃO JWT (substitui AWS Cognito)
# -------------------------------------------------------
JWT_SECRET=troque_por_uma_string_aleatoria_longa_e_segura
JWT_EXPIRATION=7d

# -------------------------------------------------------
# EMAIL (substitui AWS SES — usa nodemailer/SMTP)
# -------------------------------------------------------
SOURCE_EMAIL=noreply@certifikedu.com
ADMIN_EMAIL=admin@certifikedu.com

# Opção 1: SMTP externo (Gmail, Brevo, Resend, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER=seu@gmail.com
# SMTP_PASS=sua_senha_de_app

# Opção 2: Mailhog local (somente para desenvolvimento)
# SMTP_HOST=localhost
# SMTP_PORT=1025

# -------------------------------------------------------
# ARMAZENAMENTO DE ARQUIVOS (substitui AWS S3)
# Esses nomes são usados como subpastas dentro de UPLOAD_DIR
# -------------------------------------------------------
UPLOAD_DIR=./uploads
APP_S3_BUCKET_CLOUDFRONT=certifikedu-cloudfront
APP_S3_BUCKET=certifikedu-nest

# -------------------------------------------------------
# URLs PÚBLICAS DA VPS
# -------------------------------------------------------
# URL base para servir as imagens dos emails (logo, etc.)
ASSETS_URL=http://31.97.91.29:3001

# URL base para imagens de certificados servidas publicamente
CLOUDFRONT_IMAGES=http://31.97.91.29:3001/uploads/certifikedu-cloudfront

# URL do template padrão de certificado
CERTIFICATE_PUBLIC_IMAGE_TEMPLATE_URL=http://31.97.91.29:3001/uploads/certifikedu-cloudfront/default-template.png

# -------------------------------------------------------
# SERVIÇO DE PDI (IA)
# -------------------------------------------------------
AI_SERVICE_BASE_URL=http://31.97.91.29:3013
PdiJwtSecret=troque_por_outra_string_aleatoria_segura

# -------------------------------------------------------
# AMBIENTE
# -------------------------------------------------------
ENVIRONMENT_TYPE=production

# Habilidades válidas para o sistema
VALID_HABILITIES=python,typescript
